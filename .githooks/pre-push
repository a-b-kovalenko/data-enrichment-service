#!/bin/sh

# Prevent direct updates and deletion of protected primary branches.
while read -r localRef localSha remoteRef remoteSha; do
  case "$remoteRef" in
    refs/heads/main|refs/heads/master)
      printf '%s\n' "Direct pushes to ${remoteRef#refs/heads/} are forbidden." >&2
      printf '%s\n' "Push a feature branch and merge it through a pull request instead." >&2
      exit 1
      ;;
  esac
done

exit 0
